# Создайте .gitignore файл
cat > .gitignore << 'EOF'
# Compiled files
target/
*.class
*.jar
*.war
*.ear

# IDE files
.idea/
*.iml
*.iws
*.ipr
.settings/
.classpath
.project
.springBeans
.metadata
bin/
tmp/

# Logs
logs/
*.log

# Database
data/

# Google OAuth tokens
tokens/
*.token
*.tokens
**/StoredCredential
**/tokens/

# Credentials
credentials.json
**/credentials.json
application-local.properties
application-dev.properties
application-secret.properties

# OS metadata
.DS_Store
Thumbs.db
desktop.ini

# Maven
log/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
dependency-reduced-pom.xml
buildNumber.properties
EOF